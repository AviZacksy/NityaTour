# Copy this file to `.env.local` and fill real values there.
# `.env.local` is gitignored — yahan sirf example keys hain, secrets mat likho.

ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your-strong-password

# Long random string (e.g. `openssl rand -hex 32`)
ADMIN_SESSION_SECRET=replace-with-long-random-secret
